{
  "name": "neurolearn-3d",
  "version": "1.0.0",
  "description": "An interactive 3D learning platform powered by AI for educational content visualization",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=client\" \"npm run dev --workspace=server\"",
    "build": "npm run build --workspaces",
    "start": "concurrently \"npm start --workspace=client\" \"npm start --workspace=server\"",
    "prisma:migrate": "prisma migrate dev",
    "prisma:generate": "prisma generate"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
