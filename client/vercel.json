# Vercel Configuration for Next.js deployment

{
  "buildCommand": "npm run build --workspace=client",
  "outputDirectory": "client/.next",
  "installCommand": "npm install",
  "framework": "nextjs",
  "env": [
    {
      "key": "NEXT_PUBLIC_SERVER_URL",
      "value": "@server_url"
    },
    {
      "key": "NEXT_PUBLIC_MODELS_PATH",
      "value": "/models"
    }
  ]
}
